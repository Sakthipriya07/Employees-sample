/* Google Font */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Poppins', sans-serif;
}

body {
  min-height: 100vh;
  background: linear-gradient(
    135deg,
    #0f172a,
    #1e3a8a,
    #2563eb
  );
  padding: 30px;
}

/* Main Container */
.container {
  max-width: 1200px;
  margin: auto;
  background: #ffffff;
  border-radius: 20px;
  padding: 25px;
  box-shadow: 0 15px 35px rgba(0,0,0,0.2);
}

/* Heading */
h1,
h2 {
  text-align: center;
  color: #1e3a8a;
  margin-bottom: 20px;
}

/* Search & Add Button */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25px;
  flex-wrap: wrap;
  gap: 10px;
}

.top-bar input {
  width: 320px;
  padding: 12px;
  border: 2px solid #dbeafe;
  border-radius: 10px;
  outline: none;
  font-size: 15px;
}

.top-bar input:focus {
  border-color: #2563eb;
}

/* Add Employee */
.top-bar button {
  background: #2563eb;
  color: white;
  padding: 12px 18px;
  border-radius: 10px;
  border: none;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.top-bar button:hover {
  background: #1d4ed8;
  transform: translateY(-2px);
}

/* Table */
table {
  width: 100%;
  border-collapse: collapse;
  overflow: hidden;
  border-radius: 15px;
}

thead {
  background: #2563eb;
  color: white;
}

th {
  padding: 15px;
  text-align: left;
}

td {
  padding: 14px;
  border-bottom: 1px solid #e5e7eb;
}

tbody tr:hover {
  background: #eff6ff;
  transition: 0.3s;
}

/* Buttons */
.edit-btn {
  background: #2563eb;
  color: white;
  border: none;
  padding: 9px 14px;
  border-radius: 8px;
  cursor: pointer;
  margin-right: 8px;
  font-weight: 500;
}

.edit-btn:hover {
  background: #1d4ed8;
}

.delete-btn {
  background: #dc2626;
  color: white;
  border: none;
  padding: 9px 14px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 500;
}

.delete-btn:hover {
  background: #b91c1c;
}

/* Form Card */
.form-container {
  max-width: 500px;
  margin: 30px auto;
  background: white;
  padding: 30px;
  border-radius: 20px;
  box-shadow: 0 15px 35px rgba(0,0,0,0.15);
}

.form-container form {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.form-container input {
  padding: 12px;
  border: 2px solid #dbeafe;
  border-radius: 10px;
  outline: none;
  font-size: 15px;
}

.form-container input:focus {
  border-color: #2563eb;
}

/* Save / Update Button */
.form-container button {
  background: #2563eb;
  color: white;
  border: none;
  padding: 13px;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
}

.form-container button:hover {
  background: #1d4ed8;
}

/* Responsive */
@media (max-width: 768px) {
  .top-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .top-bar input {
    width: 100%;
  }

  table {
    display: block;
    overflow-x: auto;
  }
}
